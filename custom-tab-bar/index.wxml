<!--
  自定义底部导航栏
  中间为 C 位大圆悬浮按钮
-->
<view class="tab-bar {{dimmed ? 'dimmed' : ''}}">
  <!-- 左：巅峰 -->
  <view class="tab-item" data-index="0" bindtap="switchTab">
    <view class="tab-icon {{selected === 0 ? 'active' : ''}}">⛰</view>
    <text class="tab-text {{selected === 0 ? 'active' : ''}}">巅峰</text>
  </view>

  <!-- 中：攀登（C位大圆） -->
  <view class="tab-item center" data-index="1" bindtap="switchTab">
    <view class="center-button {{selected === 1 ? 'active' : ''}}">
      <text class="center-icon">▲</text>
    </view>
    <text class="tab-text center-text {{selected === 1 ? 'active' : ''}}">攀登</text>
  </view>

  <!-- 右：共建 -->
  <view class="tab-item" data-index="2" bindtap="switchTab">
    <view class="tab-icon {{selected === 2 ? 'active' : ''}}">🤝</view>
    <text class="tab-text {{selected === 2 ? 'active' : ''}}">共建</text>
  </view>
</view>
