/**
 * 自定义 TabBar 样式
 * C 位大圆悬浮 + 凹槽视觉 + CSS 绘制图标
 */

/* ========== 整体容器 ========== */
.tab-bar-wrapper {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  transition: opacity 0.3s ease;
}

.tab-bar-wrapper.dimmed {
  opacity: 0.3;
  pointer-events: none;
}

/* ========== 背景层（带凹槽） ========== */
.tab-bar-bg {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: flex-start;
  height: calc(120rpx + env(safe-area-inset-bottom));
}

.bg-left,
.bg-right {
  flex: 1;
  height: 100%;
  background: rgba(0, 26, 36, 0.96);
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.bg-notch {
  display: flex;
  align-items: flex-start;
  width: 180rpx;
  height: 100%;
  position: relative;
}

.notch-curve {
  width: 36rpx;
  height: 54rpx;
  position: relative;
}

.left-curve {
  background: rgba(0, 26, 36, 0.96);
  border-radius: 0 0 36rpx 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  border-right: 1rpx solid rgba(255, 255, 255, 0.06);
}

.right-curve {
  background: rgba(0, 26, 36, 0.96);
  border-radius: 0 0 0 36rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  border-left: 1rpx solid rgba(255, 255, 255, 0.06);
}

.notch-space {
  flex: 1;
  height: 100%;
  background: transparent;
}

/* ========== 内容层 ========== */
.tab-bar-content {
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 120rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 普通标签项 ========== */
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 14rpx 0 16rpx;
}

/* 图标容器 */
.icon-box {
  width: 52rpx;
  height: 44rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  margin-bottom: 6rpx;
}

/* 标签文字 */
.tab-label {
  font-size: 22rpx;
  color: rgba(136, 153, 166, 0.7);
  letter-spacing: 2rpx;
  transition: color 0.3s ease;
}

.tab-label.active {
  color: #D34941;
  font-weight: 500;
}

/* ========== CSS 山峰图标（巅峰） ========== */
.icon-mountain {
  position: relative;
  width: 44rpx;
  height: 36rpx;
}

/* 大山 */
.mountain-big {
  position: absolute;
  bottom: 0;
  left: 4rpx;
  width: 0;
  height: 0;
  border-left: 18rpx solid transparent;
  border-right: 18rpx solid transparent;
  border-bottom: 32rpx solid rgba(136, 153, 166, 0.5);
  transition: border-bottom-color 0.3s ease;
}

.icon-mountain.active .mountain-big {
  border-bottom-color: #D34941;
}

/* 小山 */
.mountain-small {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 0;
  height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-bottom: 22rpx solid rgba(136, 153, 166, 0.35);
  transition: border-bottom-color 0.3s ease;
}

.icon-mountain.active .mountain-small {
  border-bottom-color: rgba(211, 73, 65, 0.6);
}

/* ========== CSS 人物图标（共建） ========== */
.icon-people {
  position: relative;
  width: 36rpx;
  height: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 头部圆形 */
.people-head {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(136, 153, 166, 0.5);
  margin-bottom: 3rpx;
  transition: border-color 0.3s ease;
}

.icon-people.active .people-head {
  border-color: #D34941;
}

/* 身体弧形 */
.people-body {
  width: 30rpx;
  height: 16rpx;
  border: 3rpx solid rgba(136, 153, 166, 0.5);
  border-bottom: none;
  border-radius: 16rpx 16rpx 0 0;
  transition: border-color 0.3s ease;
}

.icon-people.active .people-body {
  border-color: #D34941;
}

/* ========== C 位大圆按钮 ========== */
.tab-item.center-item {
  position: relative;
  flex: 1.2;
}

.center-btn-ring {
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -76rpx;
  margin-bottom: 0;
  background: rgba(0, 26, 36, 0.96);
  box-shadow: 0 0 0 1rpx rgba(255, 255, 255, 0.06);
}

.center-btn {
  width: 114rpx;
  height: 114rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D34941 0%, #E67E22 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(211, 73, 65, 0.4);
  transition: transform 0.2s ease, box-shadow 0.3s ease;
}

.center-btn.active {
  box-shadow: 0 10rpx 40rpx rgba(211, 73, 65, 0.55);
  transform: scale(1.04);
}

.center-btn:active {
  transform: scale(0.92);
}

/* 中间箭头（CSS 三角 + 竖线） */
.center-arrow-icon {
  width: 0;
  height: 0;
  border-left: 16rpx solid transparent;
  border-right: 16rpx solid transparent;
  border-bottom: 22rpx solid rgba(255, 255, 255, 0.95);
  position: relative;
  margin-top: -6rpx;
}

.center-label {
  margin-top: 2rpx;
}
