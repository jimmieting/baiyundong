/* 自定义底部导航栏 V1.0 */

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #003344;
  z-index: 10;
  transition: opacity 0.3s ease;
}

.tab-bar.dimmed {
  opacity: 0.3;
}

.tab-bar-border {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.1);
}

.tab-bar-items {
  display: flex;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom);
  position: relative;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 11;
}

/* 侧边标签 - 行内布局 */
.tab-icon-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.tab-icon {
  font-size: 28rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #8899A6;
}

.tab-bar-item.active .tab-text {
  color: #D34941;
  font-weight: 500;
}

/* 中间C位按钮 - 悬浮感 */
.tab-center {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  z-index: 999;
}

.center-button {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  /* 黛青渐变 */
  background: linear-gradient(135deg, #004E64 0%, #003344 100%);
  /* 外发光阴影 */
  box-shadow: 0 10rpx 30rpx rgba(0, 78, 100, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  /* 向上偏移产生悬浮感 */
  margin-top: -60rpx;
  transition: transform 0.2s ease;
}

.center-button:active {
  transform: scale(0.95);
}

/* C位按钮内部 - column布局 */
.center-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.center-icon {
  font-size: 60rpx;
}

.center-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #F2F2F2;
}
