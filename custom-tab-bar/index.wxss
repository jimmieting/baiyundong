/**
 * 自定义 TabBar 样式
 * C 位大圆悬浮设计
 */

.tab-bar {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: linear-gradient(180deg, rgba(0, 26, 36, 0.95) 0%, rgba(0, 51, 68, 0.98) 100%);
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  z-index: 999;
  transition: opacity 0.3s ease;
}

.tab-bar.dimmed {
  opacity: 0.3;
  pointer-events: none;
}

/* 普通标签项 */
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0 16rpx;
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
  opacity: 0.5;
  transition: opacity 0.3s ease;
}

.tab-icon.active {
  opacity: 1;
}

.tab-text {
  font-size: 22rpx;
  color: #8899A6;
  transition: color 0.3s ease;
}

.tab-text.active {
  color: #D34941;
}

/* C 位大圆按钮 */
.tab-item.center {
  position: relative;
  margin-top: -60rpx;
}

.center-button {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D34941 0%, #E67E22 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(211, 73, 65, 0.4);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.center-button.active {
  box-shadow: 0 12rpx 32rpx rgba(211, 73, 65, 0.6);
}

.center-button:active {
  transform: scale(0.92);
}

.center-icon {
  font-size: 36rpx;
  color: #F2F2F2;
}

.center-text {
  margin-top: 4rpx;
}
