<!-- 白云洞登山局 - 记录详情 V1.0 -->

<view class="container">
  <!-- 顶部 -->
  <view class="header">
    <view class="back-btn" bindtap="goBack">←</view>
    <text class="title">攀登记录</text>
  </view>

  <block wx:if="{{loading}}">
    <view class="loading">加载中...</view>
  </block>
  <block wx:elif="{{record}}">
    <!-- 核心成绩 -->
    <view class="result-card glass-card">
      <text class="result-title">{{isPB ? '🎉 新纪录！' : '攀登完成'}}</text>
      <text class="result-duration">{{record.formattedDuration}}</text>
      <text class="result-label">总用时</text>
      
      <view class="result-comparison" wx:if="{{record.comparison}}">
        <text class="comparison-text">{{record.comparison}}</text>
      </view>

      <!-- 称号 -->
      <view class="medal">
        <text class="medal-icon">{{medal.icon}}</text>
        <text class="medal-name">{{medal.name}}</text>
      </view>
    </view>

    <!-- 详细数据 -->
    <view class="detail-card glass-card">
      <view class="detail-row">
        <text class="detail-label">开始时间</text>
        <text class="detail-value">{{record.formattedStartTime}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">结束时间</text>
        <text class="detail-value">{{record.formattedEndTime}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">起点海拔</text>
        <text class="detail-value">{{record.start_alt || '--'}} 米</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">终点海拔</text>
        <text class="detail-value">{{record.end_alt || '--'}} 米</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">海拔爬升</text>
        <text class="detail-value">{{record.altitudeDelta || '--'}} 米</text>
      </view>
    </view>

    <!-- 海拔折线图（预留） -->
    <view class="chart-card glass-card">
      <text class="chart-title">海拔轨迹</text>
      <view class="chart-placeholder">
        <text class="chart-hint">海拔图表开发中</text>
      </view>
    </view>

    <!-- 隐藏的Canvas用于生成海报 -->
  <canvas canvas-id="poster-canvas" style="width: 300px; height: 500px; position: fixed; left: -9999px;"></canvas>

  <!-- 操作按钮 -->
    <view class="action-buttons">
      <button class="action-btn primary" bindtap="generatePoster">
        <text>生成荣誉海报</text>
      </button>
      <button class="action-btn" bindtap="goHome">
        <text>返回首页</text>
      </button>
    </view>
  </block>
  <block wx:else>
    <view class="empty">
      <text>记录不存在</text>
    </view>
  </block>
</view>
