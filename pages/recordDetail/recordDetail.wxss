/* 白云洞登山局 - 记录详情 V1.0 */

.container {
  padding: 24rpx;
  min-height: auto;
  padding-top: 120rpx;
  padding-bottom: 120rpx;
}

.header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.back-btn {
  font-size: 40rpx;
  color: #F2F2F2;
  padding: 8rpx 16rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
  color: #F2F2F2;
}

/* 结果卡片 */
.result-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 28rpx;
  color: #8899A6;
  margin-bottom: 16rpx;
}

.result-duration {
  font-size: 96rpx;
  font-weight: 700;
  color: #F2F2F2;
}

.result-label {
  font-size: 24rpx;
  color: #8899A6;
  margin-bottom: 24rpx;
}

.result-comparison {
  background: rgba(211, 73, 65, 0.15);
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.comparison-text {
  font-size: 26rpx;
  color: #D34941;
}

/* 勋章 */
.medal {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.medal-icon {
  font-size: 64rpx;
}

.medal-name {
  font-size: 28rpx;
  color: #8899A6;
  letter-spacing: 2rpx;
}

/* 详情卡片 */
.detail-card {
  margin-bottom: 24rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 26rpx;
  color: #8899A6;
}

.detail-value {
  font-size: 26rpx;
  color: #F2F2F2;
}

/* 图表卡片 */
.chart-card {
  margin-bottom: 32rpx;
}

.chart-title {
  display: block;
  font-size: 28rpx;
  color: #8899A6;
  margin-bottom: 16rpx;
}

.chart-placeholder {
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12rpx;
}

.chart-hint {
  font-size: 24rpx;
  color: #8899A6;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #D34941 0%, #E67E22 100%);
  color: #F2F2F2;
}

.action-btn:not(.primary) {
  background: rgba(255, 255, 255, 0.08);
  color: #F2F2F2;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.loading, .empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #8899A6;
}
