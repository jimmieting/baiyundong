/**
 * 启动页样式
 */

.splash {
  width: 100vw;
  height: 100vh;
  background: linear-gradient(180deg, #001A24 0%, #003344 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: opacity 0.3s ease;
}

.splash.fade-out {
  opacity: 0;
}

.splash-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 80rpx;
}

.brand-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #F2F2F2;
  letter-spacing: 12rpx;
}

.brand-divider {
  width: 60rpx;
  height: 4rpx;
  background: #D34941;
  margin: 40rpx 0;
  border-radius: 2rpx;
}

.quote {
  font-size: 32rpx;
  font-style: italic;
  color: #F2F2F2;
  text-align: center;
  line-height: 1.6;
  opacity: 0.85;
}

.slogan {
  position: absolute;
  bottom: 120rpx;
  font-size: 24rpx;
  color: #8899A6;
  letter-spacing: 8rpx;
}
