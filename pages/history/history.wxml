<!--
  历史记录列表页
-->
<view class="page page-slide-up">
  <!-- 加载中 -->
  <view class="loading-tip" wx:if="{{loading}}">
    <text class="text-l3">加载中...</text>
  </view>

  <!-- 离线/错误提示 -->
  <view class="offline-hint" wx:if="{{loadError && list.length > 0}}">
    <text class="offline-hint-text" wx:if="{{errorType === 'deploy'}}">云函数未部署，请先部署相关云函数</text>
    <text class="offline-hint-text" wx:else>网络不佳，显示缓存数据</text>
  </view>

  <!-- 空态 -->
  <view class="empty-tip" wx:if="{{empty && !loading}}">
    <text class="empty-icon">🏔</text>
    <text class="text-l3">{{loadError ? (errorType === 'deploy' ? '云函数未部署' : '网络不佳，下拉刷新重试') : '还没有攀登记录'}}</text>
    <text class="text-l3" style="margin-top: 8rpx;" wx:if="{{!loadError}}">去攀登页开始你的第一次挑战吧</text>
  </view>

  <!-- 记录列表 -->
  <view
    wx:for="{{list}}"
    wx:key="_id"
    class="record-card glass-card"
    data-id="{{item._id}}"
    bindtap="goDetail"
  >
    <view class="record-header">
      <text class="record-date">{{item.dateText}}</text>
      <view class="record-status {{item.status === 'COMPLETED' ? 'completed' : item.status === 'SUSPECT' ? 'suspect' : 'running'}}">
        <text>{{item.statusText}}</text>
      </view>
    </view>
    <view class="record-body">
      <text class="record-duration text-l1">{{item.durationText}}</text>
      <text class="record-badge" wx:if="{{item.badge}}">{{item.badge}}</text>
    </view>
  </view>
</view>
