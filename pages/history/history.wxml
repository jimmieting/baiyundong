<!-- 白云洞登山局 - 历史记录 V1.0 -->

<view class="container">
  <!-- 标题 -->
  <view class="header">
    <view class="back-btn" bindtap="handleBack">←</view>
    <text class="title">历史轨迹</text>
  </view>

  <!-- 历史列表 -->
  <scroll-view scroll-y class="history-list">
    <block wx:if="{{loading}}">
      <view class="loading">加载中...</view>
    </block>
    <block wx:elif="{{list.length === 0}}">
      <view class="empty">
        <text>暂无攀登记录</text>
        <text class="empty-hint">去登山吧！</text>
      </view>
    </block>
    <block wx:else>
      <navigator 
        url="/pages/recordDetail/recordDetail?id={{item._id}}" 
        class="history-item"
        wx:for="{{list}}" 
        wx:key="_id"
      >
        <view class="item-left">
          <text class="item-date">{{item.formattedDate}}</text>
          <text class="item-status {{item.status}}">{{item.statusText}}</text>
        </view>
        <view class="item-right">
          <text class="item-duration">{{item.formattedDuration}}</text>
          <text class="item-arrow">→</text>
        </view>
      </navigator>
    </block>
  </scroll-view>
</view>
