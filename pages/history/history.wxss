/* 白云洞登山局 - 历史记录 V1.0 */

.container {
  padding: 24rpx;
  min-height: auto;
  padding-top: 120rpx;
  padding-bottom: 120rpx;
}

.header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.back-btn {
  font-size: 40rpx;
  color: #F2F2F2;
  padding: 8rpx 16rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
  color: #F2F2F2;
}

.history-list {
  height: calc(100vh - 220rpx);
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.item-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.item-date {
  font-size: 28rpx;
  color: #F2F2F2;
}

.item-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx.item-status.COM;
}

PLETED {
  background: rgba(46, 204, 113, 0.2);
  color: #2ECC71;
}

.item-status.RUNNING {
  background: rgba(211, 73, 65, 0.2);
  color: #D34941;
}

.item-status.SUSPECT {
  background: rgba(255, 77, 79, 0.2);
  color: #FF4D4F;
}

.item-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.item-duration {
  font-size: 32rpx;
  font-weight: 600;
  color: #D34941;
}

.item-arrow {
  font-size: 32rpx;
  color: #8899A6;
}

.loading, .empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #8899A6;
}

.empty-hint {
  font-size: 24rpx;
  margin-top: 16rpx;
}
