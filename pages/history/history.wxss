/**
 * 历史记录页样式
 */

.page {
  min-height: 100vh;
  padding: 24rpx 32rpx;
}

/* ========== 空态/加载 ========== */
.loading-tip,
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

/* ========== 离线提示 ========== */
.offline-hint {
  text-align: center;
  padding: 12rpx 24rpx;
  margin-bottom: 16rpx;
  background: rgba(255, 77, 79, 0.1);
  border-radius: 12rpx;
}

.offline-hint-text {
  font-size: 24rpx;
  color: var(--color-warning, #FF4D4F);
}

/* ========== 记录卡片 ========== */
.record-card {
  margin-bottom: 20rpx;
}

.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.record-date {
  font-size: 26rpx;
  color: var(--color-muted);
}

.record-status {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.record-status.completed {
  background: rgba(211, 73, 65, 0.15);
  color: var(--color-accent);
}

.record-status.suspect {
  background: rgba(255, 77, 79, 0.15);
  color: var(--color-warning);
}

.record-status.running {
  background: rgba(136, 153, 166, 0.15);
  color: var(--color-muted);
}

.record-body {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.record-duration {
  font-size: 56rpx;
}

.record-badge {
  font-size: 28rpx;
  color: var(--color-accent);
}
