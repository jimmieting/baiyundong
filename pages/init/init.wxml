<!-- 白云洞登山局 - 数据初始化页面 -->

<view class="container">
  <view class="header">
    <text class="title">白云洞登山局 · 数据初始化</text>
  </view>

  <view class="content">
    <text class="desc">点击下方按钮初始化文化数据和共建者名录</text>
    
    <button 
      class="init-btn" 
      bindtap="initData" 
      loading="{{loading}}" 
      disabled="{{loading}}"
    >
      {{loading ? '初始化中...' : '开始初始化'}}
    </button>

    <view class="result" wx:if="{{result}}">
      <text class="result-title">初始化结果：</text>
      <text class="result-msg">{{result}}</text>
    </view>
  </view>

  <button class="back-btn" bindtap="goBack">返回主页</button>
</view>
