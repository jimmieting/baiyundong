/* 白云洞登山局 - 数据初始化页面 */

.container {
  padding: 24rpx 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: linear-gradient(180deg, #001A24 0%, #003344 100%);
  background-color: #003344;
  padding-top: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header {
  margin-bottom: 60rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 500;
  color: #F2F2F2;
  letter-spacing: 4rpx;
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.desc {
  font-size: 28rpx;
  color: #8899A6;
  margin-bottom: 60rpx;
}

.init-btn {
  width: 300rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #D34941 0%, #E67E22 100%);
  border-radius: 40rpx;
  color: #F2F2F2;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result {
  margin-top: 60rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.result-title {
  display: block;
  font-size: 24rpx;
  color: #8899A6;
  margin-bottom: 12rpx;
}

.result-msg {
  display: block;
  font-size: 26rpx;
  color: #2ECC71;
}

.back-btn {
  width: 200rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
  color: #8899A6;
  font-size: 24rpx;
  margin-top: 40rpx;
}
