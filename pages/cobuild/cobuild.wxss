/* 白云洞登山局 - 共建页面 V1.0 */

.container {
  padding: 24rpx;
  min-height: auto;
  padding-top: 120rpx;
  padding-bottom: 120rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 500;
  letter-spacing: 8rpx;
  color: #F2F2F2;
}

/* 文化卡片 */
.culture-card {
  margin-bottom: 32rpx;
}

.culture-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.culture-icon {
  font-size: 48rpx;
}

.culture-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #F2F2F2;
  letter-spacing: 4rpx;
}

.culture-content .quote {
  display: block;
  font-size: 28rpx;
  font-style: italic;
  color: #F2F2F2;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.culture-content .description {
  display: block;
  font-size: 26rpx;
  color: #8899A6;
  line-height: 1.6;
}

.history-section {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #8899A6;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.history-text {
  display: block;
  font-size: 26rpx;
  color: #8899A6;
  line-height: 1.6;
}

/* 共建者名录 */
.cobuilder-section {
  margin-bottom: 32rpx;
}

.cobuilder-list {
  display: flex;
  gap: 24rpx;
  padding: 16rpx 0;
  white-space: nowrap;
}

.cobuilder-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.cobuilder-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.cobuilder-name {
  font-size: 22rpx;
  color: #8899A6;
}

.cobuilder-name.level-5 {
  font-weight: 600;
  color: #F2F2F2;
}

.cobuilder-name.level-10 {
  font-weight: 700;
  color: #FFD700;
}

.cobuilder-badge {
  font-size: 18rpx;
  color: #8899A6;
  background: rgba(255, 255, 255, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.cobuilder-add {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: #8899A6;
  font-size: 24rpx;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-btn {
  width: 100%;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  color: #F2F2F2;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.init-data-btn {
  margin-top: 20rpx;
  background: rgba(46, 204, 113, 0.15);
  border-color: rgba(46, 204, 113, 0.3);
  color: #2ECC71;
}

/* 模态框 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 100;
}

.modal-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #001A24;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: 180rpx;
  transform: translateY(-40rpx); /* 向上平移 */
  transition: transform 0.3s ease;
  z-index: 101;
}

.modal-content.show {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #F2F2F2;
}

.modal-close {
  font-size: 40rpx;
  color: #8899A6;
  padding: 16rpx;
}

.modal-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
}

.option-icon {
  font-size: 40rpx;
}

.option-info {
  flex: 1;
}

.option-title {
  display: block;
  font-size: 28rpx;
  color: #F2F2F2;
  margin-bottom: 4rpx;
}

.option-desc {
  font-size: 24rpx;
  color: #8899A6;
}
