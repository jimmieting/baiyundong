/**
 * 共建页样式
 */

.page {
  min-height: 100vh;
  padding: 0 32rpx;
}

.page-title {
  display: block;
  text-align: center;
  padding: 24rpx 0 32rpx;
}

/* ========== 区块 ========== */
.section {
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

/* ========== 文化卡片 ========== */
.culture-card {
  margin-bottom: 16rpx;
}

.culture-text {
  font-size: 28rpx;
  color: var(--color-ivory);
  line-height: 1.7;
  opacity: 0.9;
}

/* ========== 共建者名录 ========== */
.builders-wall {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.builder-tag {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--color-muted);
}

.builder-tag.bold {
  color: var(--color-ivory);
  font-weight: 600;
}

.builder-tag.top {
  color: var(--color-accent);
  font-weight: 700;
  border: 1rpx solid rgba(211, 73, 65, 0.3);
}

.empty-builders {
  padding: 40rpx 0;
  text-align: center;
}

/* ========== 支持按钮 ========== */
.support-btn {
  text-align: center;
  padding: 28rpx;
  margin-top: 20rpx;
}

.support-text {
  font-size: 30rpx;
  color: var(--color-accent);
  letter-spacing: 4rpx;
}

/* ========== 半屏模态框 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.modal-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, #001A24 0%, #003344 100%);
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.modal-content.show {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.modal-close {
  font-size: 36rpx;
  color: var(--color-muted);
  padding: 8rpx;
}

.modal-body {
  padding-bottom: 32rpx;
}

.modal-item {
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.modal-item:last-child {
  border-bottom: none;
}

.modal-item-title {
  font-size: 30rpx;
  color: var(--color-ivory);
  display: block;
  margin-bottom: 8rpx;
}

.modal-item-desc {
  display: block;
}

/* ========== 反馈表单 ========== */
.feedback-input {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  color: var(--color-ivory);
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.feedback-submit {
  text-align: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #D34941 0%, #E67E22 100%);
  border-radius: 16rpx;
  color: #F2F2F2;
  font-size: 30rpx;
  font-weight: 500;
}

.feedback-submit.disabled {
  opacity: 0.5;
  pointer-events: none;
}
