<!--
  共建页
  文化内核 + 共建者名录 + 支持/反馈
-->
<view class="page">
  <view style="height: {{statusBarHeight}}px;"></view>

  <text class="page-title text-l2">共建</text>

  <!-- 文化卡片区 -->
  <view class="section">
    <text class="section-title text-l3">文化印记</text>
    <view
      wx:for="{{cultureCards}}"
      wx:key="index"
      class="glass-card culture-card"
    >
      <text class="culture-text">{{item.content}}</text>
    </view>
  </view>

  <!-- 共建者名录 -->
  <view class="section">
    <text class="section-title text-l3">共建者名录</text>
    <view class="builders-wall" wx:if="{{builders.length > 0}}">
      <view
        wx:for="{{builders}}"
        wx:key="index"
        class="builder-tag {{item.honor_level >= 10 ? 'top' : item.honor_level >= 5 ? 'bold' : ''}}"
      >
        <text>{{item.nickname}}</text>
      </view>
    </view>
    <view class="empty-builders" wx:if="{{buildersLoading}}">
      <text class="text-l3">名录加载中...</text>
    </view>
    <view class="empty-builders" wx:if="{{!buildersLoading && builders.length === 0}}">
      <text class="text-l3">暂无共建者</text>
    </view>
  </view>

  <!-- 支持/反馈入口 -->
  <view class="support-btn glass-card" bindtap="openModal">
    <text class="support-text">支持 / 反馈</text>
  </view>

  <!-- 半屏模态框 -->
  <view class="modal-mask {{showModal ? 'show' : ''}}" bindtap="closeModal">
    <view class="modal-content {{showModal ? 'show' : ''}}" catchtap="">
      <view class="modal-header">
        <text class="text-l2">{{showFeedback ? '技术反馈' : '支持与反馈'}}</text>
        <text class="modal-close" bindtap="closeModal">✕</text>
      </view>

      <!-- 菜单列表 -->
      <view class="modal-body" wx:if="{{!showFeedback}}">
        <view class="modal-item" bindtap="openFeedback">
          <text class="modal-item-title">技术反馈</text>
          <text class="modal-item-desc text-l3">报告问题或提出建议</text>
        </view>
        <view class="modal-item" bindtap="openDonation">
          <text class="modal-item-title">捐助支持</text>
          <text class="modal-item-desc text-l3">守护这套秩序</text>
        </view>
        <view class="modal-item" bindtap="voteSpirit">
          <text class="modal-item-title">精神共鸣</text>
          <text class="modal-item-desc text-l3">为"向上的秩序"投票</text>
        </view>
      </view>

      <!-- 反馈表单 -->
      <view class="modal-body" wx:if="{{showFeedback}}">
        <textarea
          class="feedback-input"
          placeholder="请描述你遇到的问题或建议..."
          value="{{feedbackContent}}"
          bindinput="onFeedbackInput"
          maxlength="500"
          auto-height
        />
        <view
          class="feedback-submit {{feedbackSubmitting ? 'disabled' : ''}}"
          bindtap="submitFeedback"
        >
          <text>{{feedbackSubmitting ? '提交中...' : '提交反馈'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view style="height: 180rpx;"></view>
</view>
