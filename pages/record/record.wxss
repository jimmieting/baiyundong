/**
 * 记录详情页样式
 */

.page {
  min-height: 100vh;
  padding: 24rpx 32rpx;
}

.loading-tip {
  display: flex;
  justify-content: center;
  padding: 200rpx 0;
}

/* ========== 成绩展示 ========== */
.result-hero {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.duration {
  font-size: 96rpx;
  letter-spacing: 8rpx;
}

.badge-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.badge-text {
  font-size: 32rpx;
  color: var(--color-accent);
  font-weight: 600;
}

.pb-tag {
  font-size: 24rpx;
  color: #E67E22;
  background: rgba(230, 126, 34, 0.15);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

/* ========== 数据卡片 ========== */
.data-card {
  margin-bottom: 24rpx;
}

.data-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.data-row:last-child {
  border-bottom: none;
}

.data-value {
  font-size: 30rpx;
  color: var(--color-ivory);
  font-weight: 500;
}

/* ========== 异常提示 ========== */
.suspect-bar {
  text-align: center;
  padding: 16rpx 24rpx;
  background: rgba(255, 77, 79, 0.15);
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.suspect-text {
  font-size: 26rpx;
  color: var(--color-warning);
}

/* ========== 海拔折线图 ========== */
.chart-section {
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  margin-bottom: 16rpx;
}

/* ========== 海报 Canvas（隐藏） ========== */
.poster-canvas {
  width: 375px;
  height: 560px;
  position: fixed;
  left: -9999px;
  top: -9999px;
}

/* ========== 分享操作区 ========== */
.share-section {
  margin-top: 16rpx;
  margin-bottom: 32rpx;
}

.share-title {
  display: block;
  text-align: center;
  margin-bottom: 24rpx;
  letter-spacing: 2rpx;
}

.share-actions {
  display: flex;
  gap: 24rpx;
}

.share-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 36rpx 0;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 500;
  /* 重置 button 默认样式 */
  background: none;
  border: none;
  margin: 0;
  line-height: normal;
  box-sizing: border-box;
}

.share-btn::after {
  border: none;
}

.save-btn {
  background: linear-gradient(135deg, #D34941 0%, #E67E22 100%);
  color: #F2F2F2;
}

.friend-btn {
  background: rgba(255, 255, 255, 0.08) !important;
  color: var(--color-ivory) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.12) !important;
}

/* 分享图标 */
.share-icon {
  width: 48rpx;
  height: 48rpx;
  position: relative;
}

/* 保存图标：下箭头 + 底线 */
.save-icon::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 6rpx;
  width: 4rpx;
  height: 28rpx;
  background: #F2F2F2;
  transform: translateX(-50%);
}

.save-icon::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 24rpx;
  width: 16rpx;
  height: 16rpx;
  border-bottom: 4rpx solid #F2F2F2;
  border-right: 4rpx solid #F2F2F2;
  transform: translateX(-50%) rotate(45deg);
}

/* 好友图标：右上箭头 */
.friend-icon::before {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 50%;
  width: 30rpx;
  height: 4rpx;
  background: var(--color-ivory);
  transform: translateY(-50%);
}

.friend-icon::after {
  content: '';
  position: absolute;
  right: 10rpx;
  top: 50%;
  width: 14rpx;
  height: 14rpx;
  border-top: 4rpx solid var(--color-ivory);
  border-right: 4rpx solid var(--color-ivory);
  transform: translateY(-50%) rotate(45deg);
}

/* ========== 返回链接 ========== */
.back-link {
  text-align: center;
  padding: 20rpx 0 40rpx;
}

.back-link .text-l3 {
  text-decoration: underline;
  text-underline-offset: 6rpx;
}
