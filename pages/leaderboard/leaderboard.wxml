<!-- 白云洞登山局 - 巅峰排行榜 V1.0 -->

<view class="container">
  <!-- 标题 -->
  <view class="header">
    <text class="title">巅峰榜</text>
  </view>

  <!-- 切换控制器 -->
  <view class="segment-control">
    <view 
      class="segment-item {{currentTab === 'today' ? 'active' : ''}}" 
      bindtap="switchTab" 
      data-tab="today"
    >
      今日榜
    </view>
    <view 
      class="segment-item {{currentTab === 'month' ? 'active' : ''}}" 
      bindtap="switchTab" 
      data-tab="month"
    >
      本月榜
    </view>
    <view 
      class="segment-item {{currentTab === 'all' ? 'active' : ''}}" 
      bindtap="switchTab" 
      data-tab="all"
    >
      历史榜
    </view>
  </view>

  <!-- 榜单列表 -->
  <scroll-view scroll-y class="leaderboard-list">
    <block wx:if="{{loading}}">
      <view class="loading">加载中...</view>
    </block>
    <block wx:elif="{{list.length === 0}}">
      <view class="empty">
        <text>暂无记录</text>
        <text class="empty-hint">成为第一个登顶者吧！</text>
      </view>
    </block>
    <block wx:else>
      <view 
        class="rank-item {{index < 3 ? 'top-' + (index + 1) : ''}}" 
        wx:for="{{list}}" 
        wx:key="_id"
      >
        <view class="rank-number">
          <text wx:if="{{index === 0}}">🥇</text>
          <text wx:elif="{{index === 1}}">🥈</text>
          <text wx:elif="{{index === 2}}">🥉</text>
          <text wx:else>{{index + 1}}</text>
        </view>
        <image class="avatar" src="{{item.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="user-info">
          <text class="nickname">{{item.nickname || '匿名攀登者'}}</text>
          <text class="date">{{item.formattedDate}}</text>
        </view>
        <view class="time-info">
          <text class="duration">{{item.formattedDuration}}</text>
          <text class="pace">{{item.pace}}</text>
        </view>
      </view>
    </block>
  </scroll-view>
</view>
