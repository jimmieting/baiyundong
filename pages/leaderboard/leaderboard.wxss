/* 白云洞登山局 - 排行榜页面 V1.0 */

.container {
  padding: 24rpx;
  min-height: auto;
  padding-top: 120rpx;
  padding-bottom: 120rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 500;
  letter-spacing: 8rpx;
  color: #F2F2F2;
}

/* 切换控制器 */
.segment-control {
  display: flex;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 32rpx;
}

.segment-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #8899A6;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.segment-item.active {
  background: #D34941;
  color: #F2F2F2;
  font-weight: 500;
}

/* 榜单列表 */
.leaderboard-list {
  height: calc(100vh - 280rpx);
}

.rank-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.rank-item.top-1 {
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.15) 0%, rgba(255, 180, 0, 0.1) 100%);
  border: 1rpx solid rgba(255, 215, 0, 0.3);
}

.rank-item.top-2 {
  background: linear-gradient(135deg, rgba(192, 192, 192, 0.15) 0%, rgba(160, 160, 160, 0.1) 100%);
  border: 1rpx solid rgba(192, 192, 192, 0.3);
}

.rank-item.top-3 {
  background: linear-gradient(135deg, rgba(205, 127, 50, 0.15) 0%, rgba(180, 100, 30, 0.1) 100%);
  border: 1rpx solid rgba(205, 127, 50, 0.3);
}

.rank-number {
  width: 60rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #8899A6;
  text-align: center;
}

.top-1 .rank-number {
  color: #FFD700;
}

.top-2 .rank-number {
  color: #C0C0C0;
}

.top-3 .rank-number {
  color: #CD7F32;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin: 0 20rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 28rpx;
  color: #F2F2F2;
  margin-bottom: 4rpx;
}

.date {
  font-size: 22rpx;
  color: #8899A6;
}

.time-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.duration {
  font-size: 32rpx;
  font-weight: 600;
  color: #D34941;
}

.pace {
  font-size: 22rpx;
  color: #8899A6;
}

/* 加载状态 */
.loading, .empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #8899A6;
}

.empty-hint {
  font-size: 24rpx;
  margin-top: 16rpx;
}
